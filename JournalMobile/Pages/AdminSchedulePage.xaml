<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JournalMobile.Pages.AdminSchedulePage"
             Title="Расписание"
             BackgroundColor="#CFE3FA">

    <VerticalStackLayout Padding="20" Spacing="12">

        <Label Text="Расписание"
               TextColor="Black"
               FontSize="26"
               FontAttributes="Bold"/>

        <!-- ФИЛЬТР -->
        <HorizontalStackLayout Spacing="10">

            <Picker x:Name="GroupPicker"
                    Title="Группа"
                    TextColor="Black"
                    WidthRequest="150"/>

            <Picker x:Name="SemesterPicker"
                    Title="Семестр"
                    TextColor="Black"
                    WidthRequest="200"/>

            <Button Text="Показать"
                    Clicked="OnLoadClicked"
                    BackgroundColor="#5E8DF5"
                    TextColor="White"/>
        </HorizontalStackLayout>

        <!-- РАСПИСАНИЕ -->
        <CollectionView x:Name="ScheduleCollection"
                IsGrouped="True"
                ItemsSource="{Binding}">

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Label Text="{Binding DayName}"
                   FontSize="18"
                   TextColor="Black"
                   FontAttributes="Bold"
                   Padding="0,0"
                   Margin="0,10,0,5"/>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5"
                   Padding="10"
                   BackgroundColor="White">
                        <VerticalStackLayout>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="{Binding Number, StringFormat='Пара №{0}'}"
                                TextColor="Gray"
                                FontSize="12"/>
                                <Label Text="{Binding Time}"
                                TextColor="Black"
                                FontSize="14"/> 
                            </HorizontalStackLayout>
                            
                            <Label Text="{Binding Subject}"
                            TextColor="Black"
                           FontAttributes="Bold"/>
                            <Label Text="{Binding Teacher}"
                           TextColor="DarkBlue"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Text="Добавить пару"
                Clicked="OnAddClicked"
                BackgroundColor="Green"
                TextColor="White"/>

    </VerticalStackLayout>
</ContentPage>