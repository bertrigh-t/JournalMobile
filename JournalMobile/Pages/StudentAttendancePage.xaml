<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JournalMobile.Pages.StudentAttendancePage"
             BackgroundColor="#CFE3FA"
             Title="Посещаемость">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Моя посещаемость"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="Black" />

            <CollectionView x:Name="AttendanceCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#EAF3FF"
                                Stroke="#B7C9DD"
                                StrokeThickness="1"
                                Padding="14"
                                Margin="0,6">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="8">

                                <Label Text="{Binding Subject}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#1B3A57" />

                                <Border BackgroundColor="{Binding StatusColor}"
                                        Padding="10"
                                        HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>

                                    <Label Text="{Binding StatusText}"
                                           TextColor="White"
                                           FontAttributes="Bold" />
                                </Border>

                                <Label Text="{Binding DateText}"
                                       FontSize="14"
                                       TextColor="#333333" />

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>