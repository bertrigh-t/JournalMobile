<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JournalMobile.Pages.TeacherPage"
             BackgroundColor="#CFE3FA"
             Title="Преподаватель">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Здравствуйте"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1B3A57"/>

            <!-- Кнопки -->
            <VerticalStackLayout Spacing="12">

                <Button Text="Журнал оценок"
                        Clicked="OnGradesJournalClicked"
                        BackgroundColor="#7DA8F7"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="50"/>

                <Button Text="Студенты группы"
                        Clicked="OnGroupStudentsClicked"
                        BackgroundColor="#91C483"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="50"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>