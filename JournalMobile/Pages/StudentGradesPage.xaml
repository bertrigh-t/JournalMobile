<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JournalMobile.Pages.StudentGradesPage"
             BackgroundColor="#CFE3FA"
             Title="Оценки">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Мои оценки"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="Black" />

            <CollectionView x:Name="SubjectsCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#EAF3FF"
                                Stroke="#B7C9DD"
                                StrokeThickness="1"
                                Padding="14"
                                Margin="0,6">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="10">

                                <Label Text="{Binding Subject}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#1B3A57" />

                                <FlexLayout BindableLayout.ItemsSource="{Binding Grades}"
                                            Wrap="Wrap"
                                            Direction="Row"
                                            AlignItems="Start">

                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="{Binding GradeColor}"                                                    Stroke="#9DBE3F"
                                                    StrokeThickness="1"
                                                    WidthRequest="34"
                                                    HeightRequest="34"
                                                    Margin="3">

                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6" />
                                                </Border.StrokeShape>

                                                <Label Text="{Binding Grade}"
                                                       FontSize="18"
                                                       FontAttributes="Bold"
                                                       TextColor="White"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnGradeTapped"
                                                                          CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>

                                </FlexLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>