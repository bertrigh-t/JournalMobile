<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JournalMobile.Pages.AdminUsersPage"
             BackgroundColor="#CFE3FA"
             Title="Пользователи">

    <VerticalStackLayout Padding="20"
                         Spacing="15">

        <Label Text="Пользователи"
               FontSize="30"
               FontAttributes="Bold"/>

        <Button Text="Добавить пользователя"
                Clicked="OnAddUserClicked"
                BackgroundColor="#7DA8F7"
                TextColor="Black"/>

        <CollectionView x:Name="UsersCollection">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Border BackgroundColor="#EAF3FF"
                            Padding="15"
                            Margin="0,5">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                            Tapped="OnUserTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout>

                            <Label Text="{Binding Login}"
                                   FontAttributes="Bold"
                                   FontSize="18"/>

                            <Label Text="{Binding Role}" />

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>