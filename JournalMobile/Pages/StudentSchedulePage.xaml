<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JournalMobile.Pages.StudentSchedulePage"
             BackgroundColor="#CFE3FA"
             Title="Расписание">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Полное расписание"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="Black" />

            <CollectionView x:Name="ScheduleCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#EAF3FF"
                                Stroke="#B7C9DD"
                                StrokeThickness="1"
                                Padding="14"
                                Margin="0,6">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding DayOfWeekText}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#1B3A57" />
                                <Label Text="{Binding TimeSubjectClassroom}"
                                       FontSize="16"
                                       TextColor="#333333" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>